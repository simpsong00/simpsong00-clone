---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL;
const withBase = (path = "") => {
  const cleanBase = base.endsWith("/") ? base.slice(0, -1) : base;
  const cleanPath = path.replace(/^\/+/, "");
  return cleanPath ? `${cleanBase}/${cleanPath}` : `${cleanBase}/`;
};
---
<Base title="Books" description="Books in The Quotient Series">
  <section class="section page-shell">
    <h1>Books</h1>

    <article class="card book-card split-card">
      <img src="https://www.simpsong00.com/uploads/1/3/7/0/137005184/tqc-front-hd_orig.jpg" alt="The Quantum Contingent cover" />
      <div>
        <p class="meta">Book One</p>
        <h2>The Quantum Contingent</h2>
        <p>
          A globe trotting techno-spy-thriller set in 2028 involving spies, cryptocurrency, rockets, drones, and quantum
          computing.
        </p>
        <p>
          The Quantum Contingent follows Jack, Sarah, and the team at Quotient as they battle to save humanity in this
          pop-culture-infused adventure.
        </p>
        <div class="book-actions">
          <a class="button" href="https://www.simpsong00.com/the-quantum-contingent.html">Learn more</a>
        </div>
      </div>
    </article>

    <article class="card book-card split-card">
      <img src="https://www.simpsong00.com/uploads/1/3/7/0/137005184/quantum-time-book-front_orig.jpg" alt="Quantum Time cover" />
      <div>
        <p class="meta">Book Two</p>
        <h2>Quantum Time</h2>
        <p>
          Quantum Time is the sequel to The Quantum Contingent. A mysterious threat to world leaders in the years 2028
          and 2050.
        </p>
        <p>
          The story is set in richly detailed locations around the world and is infused with technology extrapolated from
          present-day innovations.
        </p>
        <div class="book-actions">
          <a class="button" href="https://www.simpsong00.com/quantum-time.html">Learn more</a>
        </div>
      </div>
    </article>

    <div class="book-actions">
      <a class="button secondary" href={withBase("blog")}>Read the journey blog</a>
      <a class="button secondary" href={withBase("technology")}>Technology topics</a>
    </div>
  </section>
</Base>
