---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL;
const withBase = (path = "") => {
  const cleanBase = base.endsWith("/") ? base.slice(0, -1) : base;
  const cleanPath = path.replace(/^\/+/, "");
  return cleanPath ? `${cleanBase}/${cleanPath}` : `${cleanBase}/`;
};
---
<Base title="Home" description="The Quotient Series by Greg Simpson" hero={true}>
  <section class="hero hero-clean">
    <div class="hero-card">
      <h1>The Quotient Series</h1>
      <p>
        Welcome to the home of <em>The Quotient Series</em>, by author Greg Simpson.
      </p>
      <p>
        This is where you can learn all about my books, <em>The Quantum Contingent</em> and <em>Quantum Time</em>, along
        with the places and technology that inspired them.
      </p>
      <div class="book-actions">
        <a class="button" href={withBase("books")}>View books</a>
        <a class="button secondary" href={withBase("blog")}>The journey blog</a>
      </div>
    </div>
    <div class="hero-art" aria-label="The Quotient Series"></div>
  </section>

  <section class="section">
    <h2>Books</h2>
    <div class="grid two-up">
      <article class="card book-card">
        <img src="https://www.simpsong00.com/uploads/1/3/7/0/137005184/tqc-front-hd_orig.jpg" alt="The Quantum Contingent book cover" />
        <div>
          <h3>The Quantum Contingent</h3>
          <p>
            A globe trotting techno-spy-thriller set in 2028 involving spies, cryptocurrency, rockets, drones, and quantum
            computing.
          </p>
          <a class="button secondary" href="https://www.simpsong00.com/the-quantum-contingent.html">Learn more</a>
        </div>
      </article>

      <article class="card book-card">
        <img src="https://www.simpsong00.com/uploads/1/3/7/0/137005184/quantum-time-book-front_orig.jpg" alt="Quantum Time book cover" />
        <div>
          <h3>Quantum Time</h3>
          <p>
            The sequel to The Quantum Contingent. A mysterious threat to world leaders in the years 2028 and 2050.
          </p>
          <a class="button secondary" href="https://www.simpsong00.com/quantum-time.html">Learn more</a>
        </div>
      </article>
    </div>
  </section>
</Base>
