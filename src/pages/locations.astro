---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL;
const withBase = (path) => `${base}${path.replace(/^\//, "")}`;
---
<Base title="Locations" description="Locations behind the books">
  <section class="section page-shell">
    <h1>Locations</h1>
    <p>
      Both books are set in richly detailed locations around the world. Here are a few of the places featured in each
      story.
    </p>

    <div class="grid two-up">
      <article class="card">
        <h2>The Quantum Contingent</h2>
        <ul>
          <li>Boston, Massachusetts</li>
          <li>Hong Kong</li>
          <li>Moscow, Russia</li>
          <li>Mumbai, India</li>
          <li>Quebec, Canada</li>
          <li>South of Iceland</li>
          <li>Al-Fayoum, Egypt</li>
          <li>Athens, Greece</li>
          <li>Kampala, Uganda</li>
          <li>Mount Everest, Nepal</li>
          <li>Cape Canaveral, Florida</li>
        </ul>
      </article>

      <article class="card">
        <h2>Quantum Time</h2>
        <ul>
          <li>Bouren, Syria</li>
          <li>Amazon Rainforest</li>
          <li>Great Wall of China</li>
          <li>The Del, Coronado, California</li>
          <li>Masada, Israel</li>
          <li>Badlands National Park, South Dakota</li>
          <li>The White House, Washington, DC</li>
          <li>Pyramids of Egypt</li>
          <li>Oxford University, England</li>
          <li>Uluru, Northern Territory, Australia</li>
          <li>Christ the Redeemer, Rio de Janeiro</li>
        </ul>
      </article>
    </div>

    <div class="book-actions">
      <a class="button secondary" href={withBase("blog")}>See location blog posts</a>
    </div>
  </section>
</Base>
